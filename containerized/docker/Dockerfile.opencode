FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        git \
        python3 \
        libc6 \
        libstdc++6 \
    && rm -rf /var/lib/apt/lists/*

COPY .opencode/bin/opencode /usr/local/bin/opencode

RUN useradd -m -u 1000 agent

USER agent
WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/opencode"]
